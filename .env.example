# StockSense environment variables
# Copy this to .env and fill in your values

# PostgreSQL connection string
DATABASE_URL=postgresql+psycopg2://stocksense:stocksense@localhost/stocksense

# Finnhub API key (https://finnhub.io)
FINNHUB_API_KEY=your_finnhub_api_key_here

# Azure Container Registry (required for deployment)
ACR_LOGIN_SERVER=yourregistry.azurecr.io
